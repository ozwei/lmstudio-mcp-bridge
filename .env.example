# LM Studio Bridge Configuration Template

# The host where LM Studio is running. 
# If using LM Link, this should be 'localhost' to connect via your local client.
LM_HOST=localhost

# The port LM Studio is listening on. Default is 1234.
LM_PORT=1234

# Optional: Your LM Studio API Token (if enabled in settings)
LM_API_TOKEN=

# LM Link Optimization: Preferred device name for remote inference
LM_PREFERRED_DEVICE=
